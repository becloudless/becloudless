{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    ":disableRateLimiting",
    ":dependencyDashboard",
    ":semanticCommits",
    ":timezone(Europe/Paris)", // TODO
    "customManagers:dockerfileVersions",
    "local>renovate/config/presets/bcl.json5",
    "local>renovate/config/presets/go.json5",
    "local>renovate/config/presets/kube.json5",
    "local>renovate/config/presets/nixos.json5",
    "local>renovate/config/presets/githubAction.json5",
    "local>renovate/config/presets/semanticCommits.json5",
    "local>renovate/config/presets/groups.json5",
    "local>renovate/config/presets/lockFileMaintenance.json5",
    "local>renovate/config/presets/renovate.json5",
    "local>renovate/config/presets/grafana.json5",
  ],
  suppressNotifications: ["prEditedNotification", "prIgnoreNotification"],

  automergeType: "branch",
  automergeStrategy: "squash",

  branchConcurrentLimit: 0,
  // TODO platform automerge requires to put some mandatory checks, else it will be merged, even if the CI is red
  //platformAutomerge: true, // do not wait for next renovate run if the platform support automerge
  minimumReleaseAge: "3 days",
  minimumReleaseAgeBehaviour: "timestamp-optional", // timestamp-required makes renovate never creating PR for packages without timestamp
  labels: ["dependencies"],


  packageRules: [
    {
      matchUpdateTypes: ["minor", "patch", "pin", "digest"],
      automerge: true,
    },
  ],
}
