{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    ":disableRateLimiting",
    ":dependencyDashboard",
    ":semanticCommits",
    ":timezone(Europe/Paris)", // TODO
    "customManagers:dockerfileVersions",
  ],
  suppressNotifications: ["prEditedNotification", "prIgnoreNotification"],

  automergeType: "branch",
  automergeStrategy: "squash",

  branchConcurrentLimit: 0,
  // TODO platform automerge requires to put some mandatory checks, else it will be merged, even if the CI is red
  //platformAutomerge: true, // do not wait for next renovate run if the platform support automerge
  minimumReleaseAge: "3 days",
  minimumReleaseAgeBehaviour: "timestamp-optional", // timestamp-required makes renovate never creating PR for packages without timestamp
  labels: ["dependencies"],

  "github-actions": {
    enabled: true,
    pinDigests: true,
  },
  flux: {
    fileMatch: [".+\\.yaml$"],
  },
  "helm-values": {
    enabled: false, // handled by a custom manager which supports renovate comments
  },
  kubernetes: {
    fileMatch: [".+\\.yaml$"],
  },
  nix: {
    enabled: true,
  },

  // from: lockFileMaintenance.json5
  lockFileMaintenance: {
    enabled: true,
    automerge: true,
    extends: ["schedule:daily"],
  },

  // from: go.json5
  postUpdateOptions: ["gomodTidy"],

  customManagers: [
    // from: kube.json5
    {
      customType: "regex",
      description: "Docker image and tag classic helm values declaration",
      managerFilePatterns: ["**/*.yaml"],
      versioningTemplate: "{{#if versioning}}{{{versioning}}}{{else}}docker{{/if}}",
      matchStrings: [
        "image:\\s+repository:\\s*(?<depName>.+?)\\s+(#\\s*renovate:\\s*versioning=(?<versioning>.+?)\\s*)?tag:\\s*\\\"?(?<currentValue>[^\\\"\\s]+)\\\"?\\s",
      ],
      datasourceTemplate: "docker",
    },
    // from: grafana.json5
    {
      description: "Update Grafana dashboard revisions from grafana.com",
      customType: "regex",
      managerFilePatterns: ["**/*.yaml"], // TODO filter more
      matchStrings: [
        "gnetId: (?<depName>\\d+)\\s+revision: (?<currentValue>\\d+)",
      ],
      datasourceTemplate: "grafana-dashboards",
      versioningTemplate: "numeric",
    },
    // from: go.json5
    {
      customType: "regex",
      managerFilePatterns: ["**/*.go"],
      versioningTemplate: "{{#if versioning}}{{{versioning}}}{{else}}semver-coerced{{/if}}",
      matchStrings: [
        '//\\s*renovate:\\s*datasource=(?<datasource>.*?) depName=(?<depName>.*?)( extractVersion=(?<extractVersion>.*?))?( versioning=(?<versioning>.*?))?\\sconst .*? = "(?:.*?:)?(?<currentValue>[a-zA-Z0-9-.]+?)"',
      ],
    },
    // from: nixos.json5
    {
      customType: "regex",
      description: "Update versions annotated with # renovate: in .nix files",
      managerFilePatterns: ["**/*.nix"],
      matchStrings: [
        '# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>.+?)( extractVersion=(?<extractVersion>.+?))?( versioning=(?<versioning>.+?))?\\s+\\w+ = "(?<currentValue>.+?)";',
      ],
    },
  ],

  packageRules: [
    // from: bcl.json5
    {
      description: "bump bcl version fast",
      matchPackageNames: ["becloudless/becloudless"],
      minimumReleaseAge: "1 day",
      ignoreUnstable: false,
      versioning: "semver",
    },
    {
      matchPackagePatterns: ["mailu"],
      groupName: "mailu",
    },
    {
      matchPackagePatterns: ["intel-gpu"],
      groupName: "intel-gpu",
    },
    {
      matchPackageNames: ["becloudless/becloudless", "bcl"],
      groupName: "becloudless",
    },
    {
      description: "reduce renovate itself update pressure",
      matchPackageNames: ["renovate"],
      schedule: ["before 2am"],
    },
    {
      matchUpdateTypes: ["major"],
      semanticCommitType: "feat",
      commitMessagePrefix: "{{semanticCommitType}}({{semanticCommitScope}})!:",
      commitMessageExtra: "( {{currentVersion}} ➔ {{newVersion}} )",
    },
    {
      matchUpdateTypes: ["minor"],
      semanticCommitType: "feat",
      commitMessageExtra: "( {{currentVersion}} ➔ {{newVersion}} )",
    },
    {
      matchUpdateTypes: ["patch"],
      semanticCommitType: "fix",
      commitMessageExtra: "( {{currentVersion}} ➔ {{newVersion}} )",
    },
    {
      matchUpdateTypes: ["digest"],
      semanticCommitType: "chore",
      commitMessageExtra: "( {{currentDigestShort}} ➔ {{newDigestShort}} )",
    },
    {
      matchManagers: ["github-actions"],
      semanticCommitType: "ci",
      semanticCommitScope: "github-action",
      commitMessageTopic: "action {{depName}}",
    },
    {
      matchDatasources: ["github-releases"],
      semanticCommitScope: "github-release",
      commitMessageTopic: "release {{depName}}",
    },
    {
      matchDatasources: ["golang-version"],
      rangeStrategy: "bump",
    },
    {
      // Do not update gomod go version for compatibility. Update toolchain instead.
      matchDepTypes: ["golang"],
      matchDepNames: ["go"],
      enabled: false,
    },
    {
      matchUpdateTypes: ["minor", "patch", "pin", "digest"],
      automerge: true,
    },
  ],
}
