{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "github>becloudless/becloudless//renovate/global.json5",
  ],

  packageRules: [
    {
      description: "bump bcl right away. It's useful to bump cli in nixos",
      matchPackageNames: [
        "becloudless/becloudless"
      ],
      minimumReleaseAge: null
    },
  ]
}
