{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "local>renovate/config/global.json5",
  ],

  packageRules: [
    {
      description: "bump bcl right away. It's useful to bump cli in nixos",
      matchPackageNames: [
        "becloudless/becloudless"
      ],
      minimumReleaseAge: null
    },
  ],

  customManagers: [
    {
      customType: "regex",
      description: "Docker image and tag classic helm values declaration",
      managerFilePatterns: ["**/*.yaml"],
      versioningTemplate: "{{#if versioning}}{{{versioning}}}{{else}}docker{{/if}}",
      matchStrings: [
        "image:\\s+repository:\\s*(?<depName>.+?)\\s+(#\\s*renovate:\\s*versioning=(?<versioning>.+?)\\s*)?tag:\\s*\\\"?(?<currentValue>[^\\\"\\s]+)\\\"?\\s"
      ],
      datasourceTemplate: "docker"
    },
  ]
}
